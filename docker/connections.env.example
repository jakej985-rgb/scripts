# ================================
# 🔐 REQUIRED: Telegram Settings
# ================================

BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ================================
# 🤖 OPTIONAL: AI / LLM Providers
# ================================

# Local AI (Ollama — recommended, runs on your server)
OLLAMA_HOST=http://localhost:11434

# Enable AI features (true/false)
# Set to true to activate ai-agent.sh recommendations
ENABLE_AI=false

# ================================
# ⚙️ SYSTEM SETTINGS
# ================================

BACKUP_DIR=/docker/backups
LOG_DIR=/docker/logs
MAX_BACKUPS=4

# ================================
# 🚨 THRESHOLDS (v3.1)
# ================================

CPU_THRESHOLD=90
MEM_THRESHOLD=90
DISK_THRESHOLD=85

# Memory limit in MiB (anomaly detection)
MEM_LIMIT=800

# ================================
# 🔐 DASHBOARD AUTH (v4.2)
# ================================
# Users configured in /docker/dashboard/users.json
# Change default passwords before production use!

# ================================
# 🌐 CLUSTER (v5)
# ================================
# Nodes configured in /docker/nodes.json
# Add remote node URLs for multi-server management
