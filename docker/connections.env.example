# ================================
# 🔐 REQUIRED: Telegram Settings
# ================================

BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ================================
# 🤖 OPTIONAL: AI / LLM Providers
# ================================

OLLAMA_HOST=http://localhost:11434
ENABLE_AI=false

# ================================
# ⚙️ SYSTEM SETTINGS
# ================================

BACKUP_DIR=/docker/backups
LOG_DIR=/docker/logs
MAX_BACKUPS=4

# ================================
# 🚨 THRESHOLDS (v3.1)
# ================================

CPU_THRESHOLD=90
MEM_THRESHOLD=90
DISK_THRESHOLD=85
MEM_LIMIT=800

# ================================
# 🌐 CLUSTER (v5.1)
# ================================
# Master URL for node heartbeat registration
MASTER_URL=http://localhost:8888

# Port this node advertises for cluster communication
NODE_PORT=8080

# ================================
# 🔐 DASHBOARD AUTH (v4.2)
# ================================
# Users configured in /docker/dashboard/users.json
# Change default passwords before production use!

# ================================
# ⚙️ ORCHESTRATION (v6/v7)
# ================================
# scaling.json defines auto-scaling rules per service
# cluster.yml defines desired replica state
# jobs.json defines scheduled cluster-wide jobs
