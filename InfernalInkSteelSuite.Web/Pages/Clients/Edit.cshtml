@page "{id:int?}"
@model InfernalInkSteelSuite.Web.Pages.Clients.EditModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <form method="post" class="dossier-container">
            <input type="hidden" name="IsPopup" value="@Request.Query["isPopup"]" />
            <input type="hidden" name="ReturnApptId" value="@Request.Query["returnApptId"]" />
            <div class="dossier-tab">case_file_@(Model.Client.Id > 0 ? Model.Client.Id.ToString() : "NEW")</div>
            
            <div class="dossier-paper">
                <div class="dossier-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h1 class="dossier-title">@Model.Title</h1>
                        <p class="dossier-subtitle">CONFIDENTIAL CLIENT RECORD</p>
                    </div>
                    <div class="btn-group">
                        <a asp-page="/Clients/Index" class="btn btn-outline-dark">Cancel</a>
                        <button type="submit" class="btn btn-danger">Save Record</button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                <div asp-validation-summary="All" class="alert alert-warning"></div>

                <div class="row">
                    <!-- Photo Placeholder -->
                    <!-- ID Scan / Photo Auto-Grab -->
                    <div class="col-md-3 text-center mb-4">
                        <div class="id-scan-container" onclick="document.getElementById('id-scan-input').click()">
                            <input type="file" id="id-scan-input" accept="image/*" style="display:none;" />
                            <input type="hidden" asp-for="AvatarBase64" id="AvatarBase64" />
                            
                            <div class="crop-preview-container">
                                @{ var avatarUrl = !string.IsNullOrEmpty(Model.Client.PhotoPath) ? Model.Client.PhotoPath : null; }
                                @if(avatarUrl != null)
                                {
                                   <img id="avatar-preview-img" src="@avatarUrl" />
                                }
                                else
                                {
                                   <img id="avatar-preview-img" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23666' stroke-width='2'%3E%3Cscript xmlns=''/%3E%3Cpath d='M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2'/%3E%3Ccircle cx='12' cy='7' r='4'/%3E%3C/svg%3E" />
                                }
                                <div class="scan-overlay"></div>
                            </div>
                            
                            <div class="mt-3">
                                <h6 class="text-uppercase text-muted" style="letter-spacing: 1px; font-size: 0.8rem;">ID Scribe</h6>
                                <div class="btn btn-sm btn-outline-danger mt-1">Scan ID</div>
                            </div>
                        </div>
                    </div>

                    <!-- Main Info -->
                    <div class="col-md-9">
                        <h5 class="section-label">Identity</h5>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="Client.FirstName" class="form-label">First Name</label>
                                <input asp-for="Client.FirstName" class="form-control dossier-input" required />
                                <span asp-validation-for="Client.FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Client.MiddleName" class="form-label">Middle Name</label>
                                <input asp-for="Client.MiddleName" class="form-control dossier-input" />
                                <span asp-validation-for="Client.MiddleName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Client.LastName" class="form-label">Last Name</label>
                                <input asp-for="Client.LastName" class="form-control dossier-input" required />
                                <span asp-validation-for="Client.LastName" class="text-danger small"></span>
                            </div>
                             <div class="col-md-3">
                                <label asp-for="Client.Status" class="form-label">Status</label>
                                <select asp-for="Client.Status" class="form-control dossier-input" asp-items="Html.GetEnumSelectList<InfernalInkSteelSuite.Domain.ClientStatus>()"></select>
                                <span asp-validation-for="Client.Status" class="text-danger small"></span>
                            </div>
                        </div>

                        <h5 class="section-label">Contact</h5>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Client.Phone" class="form-label">Phone</label>
                                <input asp-for="Client.Phone" class="form-control dossier-input" />
                                <span asp-validation-for="Client.Phone" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Client.Email" class="form-label">Email</label>
                                <input asp-for="Client.Email" type="email" class="form-control dossier-input" />
                                <span asp-validation-for="Client.Email" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="dossier-divider" />

                <h5 class="section-label">Notes & Observations</h5>
                <div class="mb-4">
                    <textarea asp-for="Client.Notes" class="form-control dossier-textarea" rows="6" placeholder="Enter client notes..."></textarea>
                    <span asp-validation-for="Client.Notes" class="text-danger small"></span>
                </div>
            </div>
        </form>

        @if (Model.Client.Id > 0)
        {
            <div class="dossier-paper mt-4">
                <div class="dossier-header d-flex justify-content-between align-items-center mb-3">
                    <h5 class="section-label m-0">Attached Documents</h5>
                    <span class="badge bg-secondary">@Model.Documents.Count Files</span>
                </div>

                @if (Model.Documents.Count > 0)
                {
                    <div class="list-group list-group-flush mb-3">
                        @foreach (var doc in Model.Documents)
                        {
                            <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center border-bottom border-secondary">
                                <div>
                                    <i class="bi bi-paperclip me-2 text-danger"></i>
                                    <strong>@doc.Title</strong>
                                    <div class="small text-muted">Uploaded: @doc.CreatedAt.ToString("g")</div>
                                </div>
                                <button class="btn btn-sm btn-outline-dark" disabled>View</button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-3">No documents in file.</p>
                }

                <form method="post" enctype="multipart/form-data" asp-page-handler="Upload" class="mt-4 p-3 bg-light border rounded">
                    <input type="hidden" asp-for="Client.Id" />
                    <label class="form-label small text-uppercase fw-bold text-danger">Attach Evidence</label>
                    <div class="input-group">
                        <input asp-for="UploadTitle" class="form-control" placeholder="Document Title" />
                        <input asp-for="Upload" class="form-control" type="file" required />
                        <button class="btn btn-danger" type="submit">Upload</button>
                    </div>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/smartcrop/2.0.3/smartcrop.min.js"></script>
    <script>
        document.getElementById('id-scan-input').addEventListener('change', function(e) {
            var file = e.target.files[0];
            if(!file) return;
            var img = new Image();
            img.src = URL.createObjectURL(file);
            img.onload = function() {
                // SmartCrop faces detection
                SmartCrop.crop(img, {width: 200, height: 200, ruleOfThirds: false}).then(function(result) {
                    var crop = result.topCrop;
                    var canvas = document.createElement('canvas');
                    canvas.width = 200;
                    canvas.height = 200;
                    var ctx = canvas.getContext('2d');
                    ctx.drawImage(img, crop.x, crop.y, crop.width, crop.height, 0, 0, 200, 200);
                    var base64 = canvas.toDataURL('image/jpeg', 0.9);
                    
                    document.getElementById('avatar-preview-img').src = base64;
                    document.getElementById('AvatarBase64').value = base64;
                });
            }
        });
    </script>
}
