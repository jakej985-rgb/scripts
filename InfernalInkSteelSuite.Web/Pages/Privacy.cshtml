@page
@model PrivacyModel
@{
    ViewData["Title"] = "The Pact";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="dossier-paper p-5" style="min-height: 70vh;">
            <h1 class="text-center mb-4"
                style="font-family: var(--font-heading); color: var(--accent-color); text-transform: uppercase; letter-spacing: 2px;">
                The Pact</h1>

            <div style="font-family: 'Courier New', monospace; line-height: 1.6; color: #333;">
                <p><strong>ARTICLE I: DATA COLLECTION</strong></p>
                <p>By entering The Gate, you agree that your digital footprint may be recorded in the Ledger. We collect
                    only what is necessary to maintain the integrity of the Appointments and Client records.</p>

                <hr class="border-secondary my-4" />

                <p><strong>ARTICLE II: SECRECY</strong></p>
                <p>Your data is bound to this server. We do not sell, trade, or offer your soul to third-party entities,
                    demonic or otherwise, without your explicit consent.</p>

                <hr class="border-secondary my-4" />

                <p><strong>ARTICLE III: TERMINATION</strong></p>
                <p>You may request purification of your records at any time by contacting the Shop Master. Note that
                    some traces may remain in the abyssal backups for up to 30 days.</p>

                <br />
                <br />
                <div class="text-center mt-5">
                    <p><em>Signed in Blood and Code,</em></p>
                    <h3 style="font-family: 'Herr Von Muellerhoff', cursive; font-size: 3rem; color: #8a0000;">Infernal
                        Ink & Steel</h3>
                </div>
            </div>
        </div>
    </div>
</div>
