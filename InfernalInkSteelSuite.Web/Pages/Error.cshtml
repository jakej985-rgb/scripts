@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="error-abyss-container">
    <div class="error-content">
        <h1 class="error-code">404</h1>
        <h2 class="error-title">LOST IN THE ABYSS</h2>
        <p class="error-message">The page you seek has been consumed by the void.</p>

        <div class="error-actions">
            <a asp-page="/Dashboard/Index" class="btn btn-gate-primary">
                Return to Surface
            </a>
        </div>

        @if (Model.ShowRequestId)
        {
            <div class="error-debug mt-4">
                <small class="text-muted">Trace ID: @Model.RequestId</small>
            </div>
        }
    </div>
</div>

<style>
    .error-abyss-container {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: radial-gradient(circle, rgba(20, 0, 0, 0.5) 0%, transparent 70%);
    }

    .error-code {
        font-size: 8rem;
        font-family: var(--font-heading);
        color: var(--primary-color);
        text-shadow: 0 0 20px rgba(138, 0, 0, 0.5);
        margin: 0;
        line-height: 1;
    }

    .error-title {
        font-family: var(--font-heading);
        font-size: 2rem;
        letter-spacing: 5px;
        margin-bottom: 1rem;
        color: var(--text-primary);
    }

    .error-message {
        color: var(--text-secondary);
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }
</style>
