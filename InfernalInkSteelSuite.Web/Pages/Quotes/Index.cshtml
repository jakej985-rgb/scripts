@page
@model InfernalInkSteelSuite.Web.Pages.Quotes.IndexModel
@{
    ViewData["Title"] = "Quotes";
}

<section class="quotes-page">
    <header class="page-header d-flex justify-content-between align-items-center mb-4">
        <h1>Quotes</h1>
        <div class="d-flex gap-2">
            <a asp-page="/Quotes/New" class="btn btn-primary d-flex align-items-center gap-2">
                <span>+ New Smart Quote</span>
            </a>
        </div>
    </header>

    @if (Model.Quotes.Count == 0)
    {
        <div class="text-center py-5 text-muted border rounded border-secondary bg-surface">
            <h4>No quotes generated yet.</h4>
        </div>
    }
    else
    {
        <div class="quotes-grid">
            @foreach (var q in Model.Quotes)
            {
                <div class="quote-ticket">
                    <div class="ticket-header">
                        <span class="ticket-style">@q.Style</span>
                        <span class="ticket-date">@q.CreatedAt.ToString("MMM dd")</span>
                    </div>
                    <div class="ticket-body">
                        <div class="ticket-placement">
                            <i class="bi bi-person-fill"></i> @q.Placement
                        </div>
                        <div class="ticket-size">
                            @q.Width" &times; @q.Height"
                        </div>
                        <div class="ticket-time">
                            <i class="bi bi-clock"></i> @q.EstimatedHoursLow - @q.EstimatedHoursHigh hrs
                        </div>
                    </div>
                    <div class="ticket-footer">
                        <div class="ticket-price">
                            @q.PriceLow.ToString("C0") - @q.PriceHigh.ToString("C0")
                        </div>
                    </div>
                    <div class="ticket-rip"></div>
                </div>
            }
        </div>
    }
</section>
