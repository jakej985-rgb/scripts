@page
@model InfernalInkSteelSuite.Web.Pages.Legal.SoulContractModel
@{
    ViewData["Title"] = "Soul Contract";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h1 class="text-uppercase mb-2" style="color: var(--primary-color);">Soul Contract</h1>
        <p class="mb-4 text-warning"><i class="bi bi-exclamation-triangle"></i> This agreement is binding for all
            eternity.</p>

        <div class="card soul-contract-paper mb-4">
            <div class="card-body p-5">
                <h3 class="text-center font-heading text-dark mb-4">Waiver of Liability</h3>
                <div class="contract-text text-dark mb-4">
                    <p>I, the undersigned, hereby acknowledge that the ritual I am about to undergo involves the
                        permanent modification of my flesh vessel.</p>
                    <p>1. <strong>Pain & Suffering:</strong> I understand that pain is the price of beauty and accept
                        all physical sensations associated with the procedure.</p>
                    <p>2. <strong>Permanence:</strong> I acknowledge that this mark is permanent and cannot be removed
                        by mortal means without significant scarring.</p>
                    <p>3. <strong>No Refunds:</strong> The exchange of gold for ink is final. There are no returns on
                        soul binding.</p>
                    <p>4. <strong>Aftercare:</strong> I swear to follow the aftercare rituals prescribed by the artist,
                        lest my skin rot and fall from my bones.</p>
                </div>

                <div class="mb-3">
                    <label class="form-label text-dark fw-bold">Sign in Blood (Touch/Mouse)</label>
                    <canvas id="signature-pad" class="signature-pad"></canvas>
                    <div class="d-flex justify-content-end">
                        <button type="button" class="btn btn-sm btn-outline-dark"
                            onclick="clearSignature()">Clear</button>
                    </div>
                </div>
            </div>
        </div>

        <button onclick="sealContract()" class="btn btn-primary btn-lg w-100 text-uppercase fw-bold">
            <i class="bi bi-pen-fill"></i> Seal The Contract
        </button>
    </div>
</div>

<style>
    .soul-contract-paper {
        background: #fdfbf7;
        /* Parchment color */
        color: #1a1a1a;
        background-image: url('https://www.transparenttextures.com/patterns/aged-paper.png');
        /* Subtle texture if online */
    }

    .font-heading {
        font-family: 'Oswald', sans-serif;
    }

    .signature-pad {
        border: 2px solid #8a0000;
        background: rgba(255, 255, 255, 0.5);
        width: 100%;
        height: 200px;
        cursor: crosshair;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        initSignaturePad();
    });
</script>
