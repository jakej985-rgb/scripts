@page
@model InfernalInkSteelSuite.Web.Pages.Tools.PainEstimatorModel
@{
    ViewData["Title"] = "Pain Estimator";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-6 d-flex justify-content-center">
        <!-- SVG Body Map Re-used/Simulated -->
        <div class="position-relative" style="width: 300px; height: 600px;">
             <svg viewBox="0 0 200 400" xmlns="http://www.w3.org/2000/svg" style="filter: drop-shadow(0 0 10px rgba(255,0,0,0.2));">
                <!-- Head -->
                <circle cx="100" cy="50" r="30" fill="#333" class="pain-zone" data-pain="4" data-desc="Head: The mind is weak, but the skull is thick. Moderate discomfort." onclick="showPain(this)" />
                <!-- Torso -->
                <rect x="70" y="80" width="60" height="120" fill="#333" class="pain-zone" data-pain="8" data-desc="Ribs: The cage of the soul. Expect agony." onclick="showPain(this)" />
                <!-- Arms -->
                <rect x="30" y="80" width="30" height="100" fill="#333" class="pain-zone" data-pain="3" data-desc="Arms: Flesh is willing. Bearable pain." onclick="showPain(this)" />
                <rect x="140" y="80" width="30" height="100" fill="#333" class="pain-zone" data-pain="3" data-desc="Arms: Flesh is willing. Bearable pain." onclick="showPain(this)" />
                 <!-- Legs -->
                <rect x="70" y="200" width="25" height="150" fill="#333" class="pain-zone" data-pain="6" data-desc="Thighs: Deep muscle tissue. A dull, throbbing ache." onclick="showPain(this)" />
                <rect x="105" y="200" width="25" height="150" fill="#333" class="pain-zone" data-pain="6" data-desc="Thighs: Deep muscle tissue. A dull, throbbing ache." onclick="showPain(this)" />
            </svg>
            <div class="text-center mt-3 text-muted">Select a zone to foresee your suffering.</div>
        </div>
    </div>
    
    <div class="col-md-6 d-flex flex-column justify-content-center">
        <div id="pain-readout" class="card bg-dark border-secondary p-4 d-none">
            <h2 class="text-uppercase text-white mb-3" id="zone-name">Zone Name</h2>
            
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="fs-4 text-muted">Pain Level:</span>
                <div class="pain-skulls fs-2 text-danger" id="pain-skulls">
                    <!-- Skulls injected here -->
                </div>
            </div>
            
            <p class="lead text-light fst-italic border-start border-3 border-danger ps-3" id="pain-desc">
                Description goes here.
            </p>
        </div>
        
        <div id="pain-placeholder" class="text-center text-muted opacity-50">
            <i class="bi bi-heart-pulse display-1"></i>
            <h3 class="mt-3">Awaiting Selection</h3>
        </div>
    </div>
</div>

<script>
    function showPain(el) {
        // Reset
        document.querySelectorAll('.pain-zone').forEach(z => z.style.fill = '#333');
        
        // Highlight
        el.style.fill = '#8a0000';
        
        // Data
        const painStore = el.getAttribute('data-pain');
        const desc = el.getAttribute('data-desc');
        
        // Render
        document.getElementById('pain-placeholder').classList.add('d-none');
        document.getElementById('pain-readout').classList.remove('d-none');
        document.getElementById('zone-name').innerText = "Selected Region"; // Simplification
        
        document.getElementById('pain-desc').innerText = desc;
        
        let skulls = "";
        for(let i=0; i<painStore; i++) skulls += "<i class='bi bi-radioactive'></i> "; // Using radioactive as skull proxy or if available
        document.getElementById('pain-skulls').innerHTML = skulls;
        
        // Sound
        if(painStore > 7 && typeof playSound === 'function') playSound('click'); // Or scream sound
    }
</script>

<style>
    .pain-zone { cursor: pointer; transition: fill 0.3s; }
    .pain-zone:hover { fill: #555; }
</style>
