@page
@model InfernalInkSteelSuite.Web.Pages.Tools.SkinToneSimModel
@{
    ViewData["Title"] = "Skin Tone Simulator";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-5">
        <h1 class="text-uppercase mb-4" style="color: var(--primary-color);">Flesh Simulator</h1>
        <p class="text-muted mb-4">Visualize how the ink settles into the dermis. Test contrast against various
            complexions.</p>

        <div class="card bg-dark border-secondary p-4 mb-4">
            <h5 class="text-white mb-3">1. Select Complexion</h5>
            <div class="d-flex gap-2 flex-wrap mb-4">
                <button class="btn rounded-circle p-3 border border-secondary" style="background-color: #f5e0d3"
                    onclick="setSkin('#f5e0d3')"></button>
                <button class="btn rounded-circle p-3 border border-secondary" style="background-color: #eac0a6"
                    onclick="setSkin('#eac0a6')"></button>
                <button class="btn rounded-circle p-3 border border-secondary" style="background-color: #d1a17d"
                    onclick="setSkin('#d1a17d')"></button>
                <button class="btn rounded-circle p-3 border border-secondary" style="background-color: #ac7e58"
                    onclick="setSkin('#ac7e58')"></button>
                <button class="btn rounded-circle p-3 border border-secondary" style="background-color: #78482b"
                    onclick="setSkin('#78482b')"></button>
                <button class="btn rounded-circle p-3 border border-secondary" style="background-color: #3e2617"
                    onclick="setSkin('#3e2617')"></button>
            </div>

            <h5 class="text-white mb-3">2. Choose Ink Style</h5>
            <div class="d-grid gap-2">
                <button class="btn btn-outline-light text-start"
                    onclick="setTattoo('https://via.placeholder.com/400x400/transparent/000?text=Black+Line')">Fine Line
                    Blackwork</button>
                <button class="btn btn-outline-light text-start"
                    onclick="setTattoo('https://via.placeholder.com/400x400/transparent/ff0000?text=Color+Piece')">Traditional
                    Color</button>
            </div>
        </div>
    </div>

    <div class="col-md-7 d-flex align-items-center justify-content-center bg-black rounded p-5">
        <div id="skin-canvas" class="position-relative shadow-lg rounded"
            style="width: 400px; height: 500px; background-color: #d1a17d; transition: background-color 0.5s;">
            <!-- Skin Texture Overlay -->
            <div class="position-absolute w-100 h-100 top-0 start-0"
                style="background-image: url('https://www.transparenttextures.com/patterns/leather.png'); opacity: 0.3; pointer-events: none;">
            </div>

            <!-- Tattoo Layer -->
            <div class="position-absolute w-100 h-100 top-0 start-0 d-flex align-items-center justify-content-center">
                <img id="tattoo-layer" src="https://via.placeholder.com/300x300/transparent/000?text=Tattoo+Preview"
                    class="img-fluid" style="mix-blend-mode: multiply; opacity: 0.85; filter: contrast(1.1);">
            </div>

            <div class="position-absolute bottom-0 end-0 p-3 text-muted small user-select-none">
                SIMULATION
            </div>
        </div>
    </div>
</div>

<script>
    function setSkin(color) {
        document.getElementById('skin-canvas').style.backgroundColor = color;
    }

    function setTattoo(url) {
        document.getElementById('tattoo-layer').src = url;
    }
</script>
