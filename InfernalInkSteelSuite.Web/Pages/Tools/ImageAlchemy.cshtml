@page
@model InfernalInkSteelSuite.Web.Pages.Tools.ImageAlchemyModel
@{
    ViewData["Title"] = "Image Alchemy";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-8 text-center">
        <h1 class="text-uppercase mb-4" style="color: var(--primary-color);">Image Alchemy</h1>
        <p class="text-muted mb-5">Transmute bulky visual matter into lightweight essence.</p>

        <div class="alchemy-dropzone border border-2 border-secondary border-dashed rounded p-5 mb-5 bg-dark position-relative overflow-hidden"
            id="dropzone">
            <div class="content">
                <i class="bi bi-cloud-upload display-1 text-secondary mb-3"></i>
                <h4 class="text-white">Drag & Drop Visuals Here</h4>
                <p class="text-muted">or click to summon from your device</p>
                <input type="file" class="position-absolute top-0 start-0 w-100 h-100 opacity-0"
                    style="cursor: pointer;" onchange="handleFileSelect(this)">
            </div>
            <div id="transmutation-overlay"
                class="position-absolute top-0 start-0 w-100 h-100 bg-black d-flex justify-content-center align-items-center d-none"
                style="opacity: 0.9;">
                <div class="text-center">
                    <div class="spinner-border text-primary mb-3" role="status"></div>
                    <h5 class="text-white blinking-text">Transmuting...</h5>
                </div>
            </div>
        </div>

        <div id="result-area" class="d-none">
            <div class="row align-items-center bg-dark border border-secondary rounded p-4">
                <div class="col-md-5">
                    <h6 class="text-muted text-uppercase small">Original Matter</h6>
                    <img src="https://via.placeholder.com/300" class="img-fluid rounded border border-secondary mb-2"
                        id="preview-img">
                    <div class="text-white">2.4 MB</div>
                </div>
                <div class="col-md-2 text-center">
                    <i class="bi bi-arrow-right display-4 text-primary"></i>
                </div>
                <div class="col-md-5">
                    <h6 class="text-muted text-uppercase small">Refined Essence</h6>
                    <img src="https://via.placeholder.com/300" class="img-fluid rounded border border-primary mb-2"
                        style="filter: contrast(1.2);">
                    <div class="text-success fw-bold">450 KB (-81%)</div>
                </div>
            </div>
            <button class="btn btn-outline-light mt-4" onclick="resetAlchemy()">Transmute Another</button>
        </div>
    </div>
</div>

<script>
    function handleFileSelect(input) {
        if (input.files && input.files[0]) {
            const overlay = document.getElementById('transmutation-overlay');
            overlay.classList.remove('d-none');

            // Simulate processing
            setTimeout(() => {
                overlay.classList.add('d-none');
                document.getElementById('dropzone').classList.add('d-none');
                document.getElementById('result-area').classList.remove('d-none');
                showOmen("Transmutation Complete.", "success");
            }, 2000);
        }
    }

    function resetAlchemy() {
        document.getElementById('result-area').classList.add('d-none');
        document.getElementById('dropzone').classList.remove('d-none');
    }
</script>

<style>
    .alchemy-dropzone:hover {
        border-color: var(--primary-color) !important;
        background: #111 !important;
    }

    .blinking-text {
        animation: blink 1s infinite;
    }

    @@keyframes blink {
        50% {
            opacity: 0;
        }
    }
</style>
