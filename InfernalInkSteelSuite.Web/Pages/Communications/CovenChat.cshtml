@page
@model InfernalInkSteelSuite.Web.Pages.Communications.CovenChatModel
@{
    ViewData["Title"] = "Coven Chat";
    Layout = "_Layout";
}

<div class="chat-container d-flex rounded overflow-hidden border border-secondary" style="height: 75vh;">
    <!-- Sidebar -->
    <div class="chat-sidebar bg-dark p-3 border-end border-secondary" style="width: 250px;">
        <h5 class="text-uppercase mb-4" style="color: var(--primary-color);">Channels</h5>
        <ul class="nav flex-column">
            <li class="nav-item mb-2">
                <a href="#" class="nav-link active text-white bg-secondary bg-opacity-25 rounded"><i
                        class="bi bi-hash"></i> general</a>
            </li>
            <li class="nav-item mb-2">
                <a href="#" class="nav-link text-muted hover-light"><i class="bi bi-megaphone"></i> announcements</a>
            </li>
            <li class="nav-item mb-2">
                <a href="#" class="nav-link text-muted hover-light"><i class="bi bi-bandaid"></i> client-issues</a>
            </li>
            <li class="nav-item mb-2">
                <a href="#" class="nav-link text-muted hover-light"><i class="bi bi-magic"></i> spells-and-hexes</a>
            </li>
        </ul>

        <h5 class="text-uppercase mt-4 mb-3" style="color: var(--primary-color);">Coven</h5>
        <div class="d-flex align-items-center mb-2 text-muted">
            <div class="rounded-circle bg-success me-2" style="width: 8px; height: 8px;"></div> Damien
        </div>
        <div class="d-flex align-items-center mb-2 text-muted">
            <div class="rounded-circle bg-secondary me-2" style="width: 8px; height: 8px;"></div> Lilith (Away)
        </div>
    </div>

    <!-- Chat Area -->
    <div class="chat-main flex-grow-1 d-flex flex-column bg-black">
        <div class="chat-header p-3 border-bottom border-secondary">
            <h5 class="m-0 text-white"><i class="bi bi-hash"></i> general</h5>
            <small class="text-muted">The main gathering hall.</small>
        </div>

        <div id="chat-messages" class="chat-messages flex-grow-1 p-4 overflow-auto">
            <!-- Mock History -->
            <div class="mb-3">
                <div class="small text-muted mb-1">Damien <span class="ms-2 opacity-50">10:42 AM</span></div>
                <div class="p-2 rounded bg-dark d-inline-block text-white border border-secondary">Has anyone seen the
                    restock of 3RLs?</div>
            </div>

            <div class="mb-3">
                <div class="small text-muted mb-1">Lilith <span class="ms-2 opacity-50">10:45 AM</span></div>
                <div class="p-2 rounded bg-dark d-inline-block text-white border border-secondary">I checked the Hoard.
                    We are low.</div>
            </div>
        </div>

        <div class="chat-input p-3 border-top border-secondary bg-dark">
            <div class="input-group">
                <input type="text" id="whisper-input" class="form-control bg-black text-white border-secondary"
                    placeholder="Cast a whisper...">
                <button class="btn btn-primary" onclick="castWhisper()"><i class="bi bi-send"></i></button>
            </div>
        </div>
    </div>
</div>

<script>
    function castWhisper() {
        const input = document.getElementById('whisper-input');
        const text = input.value;
        if (!text.trim()) return;

        const container = document.getElementById('chat-messages');
        const msgDiv = document.createElement('div');
        msgDiv.className = 'mb-3 text-end animation-slide-up';

        const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        msgDiv.innerHTML = `
            <div class="small text-muted mb-1">You <span class="ms-2 opacity-50">${time}</span></div>
            <div class="p-2 rounded bg-primary d-inline-block text-white shadow">${text}</div>
        `;

        container.appendChild(msgDiv);
        container.scrollTop = container.scrollHeight;
        input.value = '';

        playSound('click'); // Usage of existing sound tool
    }

    // Auto-scroll to bottom
    const box = document.getElementById('chat-messages');
    box.scrollTop = box.scrollHeight;
</script>

<style>
    .hover-light:hover {
        color: #fff !important;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 4px;
    }

    .animation-slide-up {
        animation: slideUp 0.3s;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
