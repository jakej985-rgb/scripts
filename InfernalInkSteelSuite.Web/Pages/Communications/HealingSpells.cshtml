@page
@model InfernalInkSteelSuite.Web.Pages.Communications.HealingSpellsModel
@{
    ViewData["Title"] = "Healing Spells";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h1 class="text-uppercase mb-4" style="color: var(--primary-color);">Healing Spells</h1>
        <p class="text-muted mb-5">Automated incantations sent to souls after their rituals.</p>

        <div class="card bg-dark border-secondary mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h5 class="card-title text-white">Standard Tattoo Aftercare</h5>
                        <p class="card-text text-muted small">Sent 24 hours after completion.</p>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="spell1" checked
                            onchange="toggleSpell(this)">
                        <label class="form-check-label text-success" for="spell1">Active</label>
                    </div>
                </div>
                <div class="bg-black p-3 rounded text-monospace text-secondary small mb-3 border border-secondary">
                    Greetings {ClientName}. The ink has settled. Remember to wash with unscented soap and apply the
                    salve of healing. Do not let the sun burn your new mark.
                </div>
                <button class="btn btn-sm btn-outline-light"><i class="bi bi-pencil"></i> Edit Incantation</button>
            </div>
        </div>

        <div class="card bg-dark border-secondary mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h5 class="card-title text-white">Piercing Check-in</h5>
                        <p class="card-text text-muted small">Sent 7 days after completion.</p>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="spell2" onchange="toggleSpell(this)">
                        <label class="form-check-label text-muted" for="spell2">Dormant</label>
                    </div>
                </div>
                <div class="bg-black p-3 rounded text-monospace text-secondary small mb-3 border border-secondary">
                    Greetings {ClientName}. Is the metal sitting well within your flesh? If swelling persists, return to
                    the sanctuary immediately.
                </div>
                <button class="btn btn-sm btn-outline-light"><i class="bi bi-pencil"></i> Edit Incantation</button>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleSpell(el) {
        const label = el.nextElementSibling;
        if (el.checked) {
            label.textContent = "Active";
            label.className = "form-check-label text-success";
            showOmen("Spell Activated.", "success");
        } else {
            label.textContent = "Dormant";
            label.className = "form-check-label text-muted";
            showOmen("Spell Dormant.", "info");
        }
    }
</script>
