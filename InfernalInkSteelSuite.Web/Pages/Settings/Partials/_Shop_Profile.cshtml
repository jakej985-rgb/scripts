@model InfernalInkSteelSuite.Web.Pages.Settings.IndexModel

<div class="glass-panel p-4 mb-4">
    <h4 class="text-uppercase mb-3 text-gradient-gold">Shop Profile</h4>
    <div class="row g-3">
        <div class="col-md-12">
            <label asp-for="Settings.ShopName" class="form-label">Shop Name</label>
            <input asp-for="Settings.ShopName" class="form-control infernal-input" placeholder="e.g. Infernal Ink" />
        </div>
        <!-- Add more profile fields as needed (Address, Contact, etc. if added to DTO) -->
    </div>
    <div class="mt-3 text-end">
        <button type="submit" class="btn btn-infernal-primary">Save Profile</button>
    </div>
</div>
