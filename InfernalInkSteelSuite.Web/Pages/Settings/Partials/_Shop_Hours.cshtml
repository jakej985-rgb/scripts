@model InfernalInkSteelSuite.Web.Pages.Settings.IndexModel

<div class="glass-panel p-4 mb-4">
    <h4 class="text-uppercase mb-3 text-gradient-gold">Operating Hours</h4>

    <div class="table-responsive">
        <table class="table table-borderless align-middle text-white">
            <thead>
                <tr class="text-muted text-uppercase small">
                    <th style="width: 120px;">Day</th>
                    <th style="width: 80px;">Status</th>
                    <th>Hours</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.ShopHours.Count; i++)
                {
                        <tr>
                            <td>
                                <input type="hidden" asp-for="ShopHours[i].Day" />
                                <span class="fw-bold">@Model.ShopHours[i].Day</span>
                            </td>
                            <td>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="ShopHours[i].IsOpen">
                                </div>
                            </td>
                            <td>
                                <div class="input-group input-group-sm w-75">
                                    <span class="input-group-text bg-transparent border-secondary text-light">Open</span>
                                    <input type="time" class="form-control infernal-input" asp-for="ShopHours[i].StartTime" />
                                    <span class="input-group-text bg-transparent border-secondary text-light">Close</span>
                                    <input type="time" class="form-control infernal-input" asp-for="ShopHours[i].EndTime" />
                                </div>
                            </td>
                        </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="mt-3 text-end">
         <button type="submit" class="btn btn-infernal-primary">Update Schedule</button>
    </div>
</div>
