@model InfernalInkSteelSuite.Web.Pages.Settings.IndexModel

<div class="glass-panel p-4 mb-4">
    <h4 class="text-uppercase mb-3 text-gradient-gold">Services & Pricing</h4>

    <div class="row g-4">
        <div class="col-md-6">
            <h5 class="text-light mb-3">Tattoo</h5>
            <div class="mb-3">
                <label asp-for="Settings.TattooPerHour" class="form-label">Hourly Rate ($)</label>
                <input asp-for="Settings.TattooPerHour" type="number" class="form-control infernal-input" />
            </div>
            <div class="mb-3">
                <label asp-for="Settings.ShopMinimumRate" class="form-label">Shop Minimum ($)</label>
                <input asp-for="Settings.ShopMinimumRate" type="number" class="form-control infernal-input" />
            </div>
        </div>

        <div class="col-md-6">
            <h5 class="text-light mb-3">Piercing</h5>
            <div class="mb-3">
                <label asp-for="Settings.PiercingSingle" class="form-label">Single Piercing ($)</label>
                <input asp-for="Settings.PiercingSingle" type="number" class="form-control infernal-input" />
            </div>
            <div class="mb-3">
                <label asp-for="Settings.PiercingMulti" class="form-label">Multi Piercing ($)</label>
                <input asp-for="Settings.PiercingMulti" type="number" class="form-control infernal-input" />
            </div>
        </div>

        <div class="col-12">
            <hr class="border-secondary" />
        </div>

        <div class="col-md-6">
            <h5 class="text-light mb-3">Financials</h5>
            <div class="mb-3">
                <label asp-for="Settings.TaxRate" class="form-label">Tax Rate (%)</label>
                <input asp-for="Settings.TaxRate" type="number" step="0.01" class="form-control infernal-input" />
            </div>
            <div class="mb-3">
                <label asp-for="Settings.DepositType" class="form-label">Deposit Type</label>
                <select asp-for="Settings.DepositType" class="form-select infernal-input">
                    <option value="Percentage">Percentage</option>
                    <option value="Fixed">Fixed Amount</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Settings.DepositAmount" class="form-label">Deposit Value</label>
                <input asp-for="Settings.DepositAmount" type="number" class="form-control infernal-input" />
            </div>
        </div>

        <div class="col-md-6">
            <h5 class="text-light mb-3">Policies</h5>
            <div class="mb-3">
                <label asp-for="Settings.CancellationPolicy" class="form-label">Cancellation Policy</label>
                <textarea asp-for="Settings.CancellationPolicy" class="form-control infernal-input" rows="5"></textarea>
            </div>
        </div>
    </div>

    <div class="mt-3 text-end">
        <button type="submit" class="btn btn-infernal-primary">Save Pricing</button>
    </div>
</div>
