@model InfernalInkSteelSuite.Web.Pages.Settings.IndexModel

<div class="glass-panel p-4 mb-4">
    <h4 class="text-uppercase mb-3 text-gradient-gold">Backup & Restore</h4>

    <div class="alert alert-info border-info bg-transparent text-info">
        <i class="bi bi-info-circle me-2"></i>Backups are stored on the server.
    </div>

    <div class="mb-3">
        <label asp-for="BackupSettings.BackupPath" class="form-label">Server Backup Path</label>
        <input asp-for="BackupSettings.BackupPath" class="form-control infernal-input" />
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="BackupSettings.BackupFrequency" class="form-label">Frequency</label>
            <select asp-for="BackupSettings.BackupFrequency" class="form-select infernal-input">
                <option value="Daily">Daily</option>
                <option value="Weekly">Weekly</option>
                <option value="Monthly">Monthly</option>
            </select>
        </div>
        <div class="col-md-6">
            <label asp-for="BackupSettings.RetentionDays" class="form-label">Retention (Days)</label>
            <input asp-for="BackupSettings.RetentionDays" type="number" class="form-control infernal-input" />
        </div>
    </div>

    <div class="form-check form-switch mb-4">
        <input class="form-check-input" type="checkbox" asp-for="BackupSettings.AutoBackupEnabled">
        <label class="form-check-label" asp-for="BackupSettings.AutoBackupEnabled">Enable Automatic Backups</label>
    </div>

    <div class="d-flex justify-content-between">
        <button type="button" class="btn btn-outline-light">
            <i class="bi bi-clock-history me-2"></i> Restore from Backup
        </button>
        <button type="submit" class="btn btn-infernal-primary">Save Configuration</button>
    </div>
</div>
