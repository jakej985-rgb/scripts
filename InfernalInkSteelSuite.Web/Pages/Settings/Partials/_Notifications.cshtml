@model InfernalInkSteelSuite.Web.Pages.Settings.IndexModel

<div class="glass-panel p-4 mb-4">
    <h4 class="text-uppercase mb-3 text-gradient-gold">Notifications</h4>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-header bg-transparent border-secondary text-uppercase fw-bold text-light">
                    <i class="bi bi-envelope-fill me-2"></i> Email Settings
                </div>
                <div class="card-body">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox"
                            asp-for="NotificationSettings.EmailAppointmentReminders">
                        <label class="form-check-label text-light"
                            asp-for="NotificationSettings.EmailAppointmentReminders">Send Reminders</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-header bg-transparent border-secondary text-uppercase fw-bold text-light">
                    <i class="bi bi-chat-dots-fill me-2"></i> SMS Settings
                </div>
                <div class="card-body">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox"
                            asp-for="NotificationSettings.SmsAppointmentReminders">
                        <label class="form-check-label text-light"
                            asp-for="NotificationSettings.SmsAppointmentReminders">Send Reminders</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <label asp-for="NotificationSettings.ReminderTiming" class="form-label">Default Reminder Timing</label>
            <select asp-for="NotificationSettings.ReminderTiming" class="form-select infernal-input w-auto">
                <option value="1 hour before">1 hour before</option>
                <option value="2 hours before">2 hours before</option>
                <option value="24 hours before">24 hours before</option>
                <option value="48 hours before">48 hours before</option>
            </select>
        </div>
    </div>

    <div class="mt-3 text-end">
        <button type="submit" class="btn btn-infernal-primary">Save Notifications</button>
    </div>
</div>
