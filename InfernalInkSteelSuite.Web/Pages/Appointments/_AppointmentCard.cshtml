@model InfernalInkSteelSuite.Web.Models.AppointmentDto

@{
    var now = DateTime.Now;
    var isPast = Model.EndTime < now;
    var isPastDue = Model.Status != "Completed" && isPast;

    var statusColor = "text-warning"; // Default Scheduled (Yellow)
    var statusIcon = "bi-clock";
    var statusTitle = Model.Status;

    if (Model.Status == "Completed")
    {
        statusColor = "text-success"; // Green
        statusIcon = "bi-check-circle-fill";
    }
    else if (isPastDue)
    {
        statusColor = "text-danger"; // Red
        statusIcon = "bi-exclamation-circle-fill";
        statusTitle = "Past Due";
    }
    var duration = (Model.EndTime - Model.StartTime).TotalMinutes;
}

<div class="soul-contract-card @(isPast ? "appointment-past" : "")" data-id="@Model.Id"
    onclick="openAppointmentDetails(@Model.Id)">
    <!-- Seal watermark -->


    <!-- Main Flex content -->
    <div class="d-flex justify-content-between align-items-start position-relative p-2" style="z-index: 2;">

        <!-- Left: Time & Status -->
        <div class="d-flex flex-column align-items-center me-4">
            <div class="status-rune mb-2 d-flex align-items-center justify-content-center bg-black border border-secondary rounded-circle" 
                 title="@statusTitle" style="width: 40px; height: 40px;">
                <i class="bi @statusIcon @statusColor fs-4"></i>
            </div>
            <div class="text-center">
                <div class="fw-bold fs-5">@Model.StartTime.ToString("h:mm")</div>
                <div class="small text-muted">@Model.StartTime.ToString("tt")</div>
            </div>
            <div class="mt-2 small text-muted">(@duration m)</div>
        </div>

        <!-- Middle: Info -->
        <div class="flex-grow-1 d-flex flex-column gap-1">
            <h4 class="mb-0 client-name position-relative"
                style="font-family: 'Oswald', sans-serif; text-transform: uppercase; font-size: 1.5rem; letter-spacing: 1px;">
                @(Model.Client?.FullName ?? "Walk-In Soul")
                
                <!-- Mugshot Popup Placeholder -->
                <div class="client-mugshot-popover rounded">
                    <div class="small text-uppercase text-muted mb-1">Criminally Good Ink</div>
                    <div class="fw-bold text-white">@(Model.Client?.Phone ?? "No Contact")</div>
                </div>
            </h4>

            <!-- Row 2: Artist -->
            <div class="artist-row d-flex align-items-center text-muted small">
                <span class="metal-frame me-2" style="width:28px; height:28px; display: inline-flex; align-items: center; justify-content: center;">
                    <img src="https://ui-avatars.com/api/?name=@(Model.ArtistName)&background=random&color=fff&length=2"
                        alt="@Model.ArtistName" style="width: 100%; height: 100%;" />
                </span>
                <span class="text-uppercase" style="letter-spacing: 1px;">@Model.ArtistName</span>
            </div>

            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="card-notes p-2 my-1 bg-light bg-opacity-10 rounded border border-secondary small fst-italic">
                    "@Model.Notes"
                </div>
            }

            <!-- Row 3: Financials -->
            <div class="financials-row d-flex gap-3 small my-1">
                <span class="@(Model.Status == "Confirmed" ? "blood-money-paid" : "blood-money-due")" style="font-family: 'Courier New', monospace; font-weight: 600;">
                    <i class="bi bi-cash-coin me-1"></i>Deposit: @(Model.Status == "Confirmed" ? "PAID" : "DUE")
                </span>
                <span class="text-muted" style="font-family: 'Courier New', monospace;">
                    <i class="bi bi-file-earmark-medical me-1"></i>Waiver: Pending
                </span>
            </div>

            <!-- Row 4: Service Type (Bottom) -->
            <div class="service-badge-row mt-1">
                <span class="badge bg-transparent border border-secondary text-uppercase text-secondary" 
                      style="font-family: 'Oswald', sans-serif; letter-spacing: 2px; padding: 4px 8px; border-radius: 4px;">
                    @Model.ServiceType
                </span>
            </div>
        </div>


    </div>
</div>
