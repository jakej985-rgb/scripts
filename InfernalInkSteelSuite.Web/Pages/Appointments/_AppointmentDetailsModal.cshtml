@model InfernalInkSteelSuite.Web.Models.AppointmentDetailsViewModel

@{
    var appt = Model.CurrentAppointment;
    var client = appt.Client;
}

<div class="modal-header border-bottom border-secondary">
    <div class="d-flex flex-column">
        <h5 class="modal-title font-oswald text-uppercase">
            <i class="bi bi-vector-pen me-2 text-accent"></i>Ritual for @(client?.FullName ?? "Unknown Soul")
        </h5>
        <div class="small text-muted" style="letter-spacing: 1px;">ID: #@appt.Id</div>
    </div>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body">
    <!-- Client Info Section -->
    <div class="mb-4">
        <h6 class="text-uppercase text-muted border-bottom border-dark pb-2 mb-3">
            <i class="bi bi-person-badge me-2"></i>The Vessel (Client)
        </h6>
        <div class="d-flex align-items-center gap-3">
            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fw-bold fs-3"
                style="width: 60px; height: 60px;">
                @(client?.FirstName?.FirstOrDefault())@(client?.LastName?.FirstOrDefault())
            </div>
            <div>
                <h4 class="mb-1 text-white font-oswald text-uppercase fs-3">@client?.FullName</h4>
                <div class="text-muted small">
                    <i class="bi bi-phone me-1"></i> @(client?.Phone ?? "No Phone")
                    <span class="mx-2">|</span>
                    <i class="bi bi-envelope me-1"></i> @(client?.Email ?? "No Email")
                </div>
            </div>
            <div class="ms-auto">
                <a href="#" onclick="openClientEditPopup(@(client?.Id ?? 0), @appt.Id); return false;" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-pencil"></i> Edit Profile
                </a>
            </div>
        </div>
        
        <!-- Client Notes Check -->
        @if (!string.IsNullOrWhiteSpace(client?.Notes))
        {
            <div class="mt-3 p-2 border border-danger border-opacity-25 rounded bg-danger bg-opacity-10">
                <div class="small text-danger fw-bold text-uppercase mb-1"><i class="bi bi-exclamation-triangle me-1"></i>Important Notes</div>
                <div class="small text-white">@client.Notes</div>
            </div>
        }
        else 
        {
             <div class="mt-3 p-2 border border-secondary border-dashed rounded bg-dark bg-opacity-50 text-center">
                <div class="small text-muted fst-italic">
                    <i class="bi bi-plus-circle me-1"></i>Add notes for allergies or ink irritations via <a href="#" onclick="openClientEditPopup(@(client?.Id ?? 0), @appt.Id); return false;" class="text-secondary text-decoration-underline">Edit Profile</a>
                </div>
            </div>
        }
    </div>

    <!-- Current Session Info -->
    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3 border-bottom border-dark pb-2">
            <h6 class="text-uppercase text-muted mb-0">
                <i class="bi bi-calendar-event me-2"></i>Current Session
            </h6>
            <a href="#" onclick="openAppointmentEditPopup(@appt.Id); return false;" class="btn btn-sm btn-outline-secondary border-0 text-muted">
                <i class="bi bi-pencil-square me-1"></i>Edit Details
            </a>
        </div>
        <div class="row g-3">
            <div class="col-6">
                <div class="p-3 rounded bg-dark border border-secondary h-100">
                    <div class="small text-muted mb-1">Service</div>
                    <div class="fw-bold text-accent">@appt.ServiceType</div>
                    <div class="small text-muted">(@appt.ServiceCategory)</div>
                </div>
            </div>
            <div class="col-6">
                <div class="p-3 rounded bg-dark border border-secondary h-100">
                    <div class="small text-muted mb-1">Time</div>
                    <div class="fw-bold text-white">
                        @appt.StartTime.ToString("MMM dd, yyyy") <br />
                        @appt.StartTime.ToString("h:mm tt") - @appt.EndTime.ToString("h:mm tt")
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="p-3 rounded bg-dark border border-secondary">
                    <div class="small text-muted mb-1">Notes</div>
                    <div class="fst-italic text-white">"@(string.IsNullOrWhiteSpace(appt.Notes) ? "No notes recorded." :
                        appt.Notes)"</div>
                </div>
            </div>

            <!-- Financials / Quote Section -->
            <div class="col-12">
                <div class="p-3 rounded bg-dark border border-secondary">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="small text-uppercase text-muted"><i class="bi bi-coin me-1"></i>Financials</div>
                        @{
                            var isPastDue = appt.Status != "Completed" && appt.EndTime < DateTime.Now;
                            var statusColor = "bg-warning text-dark"; // Default Scheduled
                            var statusIcon = "bi-clock";

                            if (appt.Status == "Completed")
                            {
                                statusColor = "bg-success";
                                statusIcon = "bi-check-circle-fill";
                            }
                            else if (isPastDue)
                            {
                                statusColor = "bg-danger";
                                statusIcon = "bi-exclamation-circle-fill";
                            }
                        }
                        <div class="badge @statusColor">
                            <i class="bi @statusIcon me-1"></i>
                            @(isPastDue ? "Past Due" : appt.Status)
                        </div>
                    </div>

                    <div class="row g-2 align-items-end">
                        <div class="col-12 mb-2">
                            <label class="form-label small text-muted mb-1">Smart Quote (Optional)</label>
                            <div class="dropdown">
                                <button
                                    class="btn btn-sm btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center"
                                    type="button" id="smartQuoteDropdown" data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                    <span>-- Select Smart Quote --</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-dark w-100 shadow-lg"
                                    aria-labelledby="smartQuoteDropdown">

                                    <!-- Actions -->
                                    <li>
                                        <h6 class="dropdown-header text-uppercase small text-muted">Actions</h6>
                                    </li>
                                    <li>
                                        <a class="dropdown-item text-accent" href="#"
                                            onclick="openQuotePopup(@appt.ClientId); return false;">
                                            <i class="bi bi-plus-lg me-2"></i>Create New Quote
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item text-white" href="#"
                                            onclick="refreshAppointmentDetails(@appt.Id); return false;">
                                            <i class="bi bi-arrow-clockwise me-2"></i>Refresh List
                                        </a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider border-secondary">
                                    </li>

                                    <!-- Existing Quotes -->
                                    <li>
                                        <h6 class="dropdown-header text-uppercase small text-muted">Select Existing</h6>
                                    </li>
                                    @if (Model.AvailableQuotes.Any())
                                    {
                                        @foreach (var quote in Model.AvailableQuotes)
                                        {
                                            <li>
                                                <a class="dropdown-item" href="#" data-price="@quote.PriceLow"
                                                    onclick="selectSmartQuote(this, @quote.PriceLow)">
                                                    @quote.Placement (@(quote.Style)) - $@quote.PriceLow <span
                                                        class="text-muted small ms-2">(@quote.CreatedAt.ToString("MM/dd"))</span>
                                                </a>
                                            </li>
                                        }
                                    }
                                    else
                                    {
                                        <li><span class="dropdown-item-text text-muted fst-italic small">No quotes
                                                found</span></li>
                                    }

                                    <!-- Reset -->
                                    <li>
                                        <hr class="dropdown-divider border-secondary">
                                    </li>
                                    <li><a class="dropdown-item" href="#" onclick="selectSmartQuote(this, 0)">-- Manual
                                            Entry --</a></li>
                                </ul>
                            </div>
                        </div>
                        <div class="col-10">
                            <label class="form-label small text-muted mb-1">Quoted Price ($)</label>
                            <input type="number" id="inputQuotedPrice"
                                class="form-control form-control-sm bg-black text-white border-secondary"
                                value="@(appt.QuotedPrice ?? 0)" step="0.01">
                        </div>
                        <div class="col-2">
                            <button type="button" class="btn btn-sm btn-outline-success w-100"
                                onclick="updateFinancials(@appt.Id)">
                                <i class="bi bi-save"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Past Sessions -->
    <div>
        <h6 class="text-uppercase text-muted border-bottom border-dark pb-2 mb-3">
            <i class="bi bi-clock-history me-2"></i>Past Sessions
        </h6>
        @if (Model.PastSessions.Any())
        {
            <div class="list-group list-group-flush border rounded border-secondary">
                @foreach (var past in Model.PastSessions.Where(p => p.Id != appt.Id).Take(5))
                {
                    <div
                        class="list-group-item bg-dark text-white border-secondary d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fw-bold">@past.ServiceType</div>
                            <div class="small text-muted">@past.StartTime.ToString("MMM dd, yyyy")</div>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-secondary mb-1">@past.ArtistName</span>
                            <div class="small text-accent">$@past.FinalPrice</div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-muted small fst-italic">No previous records found for this soul.</div>
        }
    </div>
</div>
<div class="modal-footer border-top border-secondary">
    <a href="#" onclick="openAppointmentEditPopup(@appt.Id); return false;" class="btn btn-outline-light">
        <i class="bi bi-pencil me-2"></i>Edit
    </a>
    <button type="button" class="btn btn-gate-primary" onclick="markCompleted(@appt.Id)">
        <i class="bi bi-check-lg me-2"></i>Complete Ritual
    </button>
</div>
