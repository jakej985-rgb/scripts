@page
@model InfernalInkSteelSuite.Web.Pages.Appointments.PurgatoryModel
@{
    ViewData["Title"] = "Purgatory (Waitlist)";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-5 fw-bold text-uppercase" style="color: var(--primary-color);">Purgatory</h1>
        <p class="text-muted">Direct the flow of souls through the ritual stages.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="/Appointments/Create" class="btn btn-outline-light">
            <i class="bi bi-plus-lg"></i> New Ritual
        </a>
    </div>
</div>

<!-- Bloodline Breadcrumb (Manual implementation for this page) -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb bloodline-breadcrumb">
        <li class="breadcrumb-item"><a href="/Dashboard/Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Appointments/Index">Appointments</a></li>
        <li class="breadcrumb-item active" aria-current="page">Purgatory</li>
    </ol>
</nav>

<div class="kanban-board">
    <!-- PENDING COLUMN -->
    <div class="kanban-column">
        <div class="kanban-header kanban-pending">
            <i class="bi bi-hourglass-split"></i> PENDING
        </div>
        <div class="kanban-body" id="pending-zone" ondrop="drop(event)" ondragover="allowDrop(event)" data-status="Pending">
            @foreach (var appt in Model.PendingAppts)
            {
                <partial name="_KanbanCard" model="appt" />
            }
        </div>
    </div>

    <!-- CONFIRMED COLUMN -->
    <div class="kanban-column">
        <div class="kanban-header kanban-confirmed">
            <i class="bi bi-check-circle"></i> CONFIRMED
        </div>
        <div class="kanban-body" id="confirmed-zone" ondrop="drop(event)" ondragover="allowDrop(event)" data-status="Confirmed">
            @foreach (var appt in Model.ConfirmedAppts)
            {
                <partial name="_KanbanCard" model="appt" />
            }
        </div>
    </div>

    <!-- COMPLETED COLUMN -->
    <div class="kanban-column">
        <div class="kanban-header kanban-completed">
            <i class="bi bi-stars"></i> COMPLETED
        </div>
        <div class="kanban-body" id="completed-zone" ondrop="drop(event)" ondragover="allowDrop(event)" data-status="Completed">
            @foreach (var appt in Model.CompletedAppts)
            {
                <partial name="_KanbanCard" model="appt" />
            }
        </div>
    </div>
</div>

<script>
    function allowDrop(ev) {
        ev.preventDefault();
    }

    function drag(ev) {
        ev.dataTransfer.setData("text", ev.target.id);
        ev.target.classList.add('dragging');
    }

    function drop(ev) {
        ev.preventDefault();
        var data = ev.dataTransfer.getData("text");
        var card = document.getElementById(data);
        card.classList.remove('dragging');
        
        // Find closest drop zone
        var dropZone = ev.target.closest('.kanban-body');
        if (dropZone) {
            dropZone.appendChild(card);
            
            // Here we would trigger an API call to update status
            var newStatus = dropZone.getAttribute('data-status');
            var id = card.getAttribute('data-id');
            showOmen(`Soul ${id} moved to ${newStatus}`, 'info');
        }
    }
</script>
