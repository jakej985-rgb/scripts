@model InfernalInkSteelSuite.Web.Pages.Appointments.IndexModel

@{
    var now = Model.SelectedDate;
    var year = now.Year;
    var month = now.Month;
    var firstDay = new DateOnly(year, month, 1);
    var daysInMonth = DateTime.DaysInMonth(year, month);
    var startDayOfWeek = (int)firstDay.DayOfWeek; // 0 = Sunday

    // Use Real Data
    var counts = Model.AppointmentCounts ?? [];
}

<div class="magma-calendar-wrapper mb-4">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="m-0 text-uppercase" style="letter-spacing: 2px;">@firstDay.ToString("MMMM yyyy")</h5>
        <div class="btn-group btn-group-sm">
            <a asp-route-Date="@firstDay.AddMonths(-1).ToString("yyyy-MM-dd")"
                class="btn btn-outline-secondary border-0">&lt;</a>
            <a asp-route-Date="@firstDay.AddMonths(1).ToString("yyyy-MM-dd")"
                class="btn btn-outline-secondary border-0">&gt;</a>
        </div>
    </div>

    <div class="magma-calendar">
        <!-- Weekday Headers -->
        @foreach (var dayName in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
        {
            <div class="text-center text-muted small fw-bold">@dayName</div>
        }

        <!-- Empty cells for start of month -->
        @for (int i = 0; i < startDayOfWeek; i++)
        {
            <div class="magma-day empty disabled"></div>
        }

        <!-- Days -->
        @for (int day = 1; day <= daysInMonth; day++)
        {
            var currentDay = new DateOnly(year, month, day);
            var isSelected = currentDay == Model.SelectedDate;
            var isToday = currentDay == DateOnly.FromDateTime(DateTime.Today);

            // Check real counts
            int count = 0;
            counts.TryGetValue(currentDay, out count);

            var heatClass = "";
            if (count > 0)
            {
                if (count >= 5) heatClass = "has-appointments-high";
                else if (count >= 3) heatClass = "has-appointments-med";
                else heatClass = "has-appointments-low";
            }

            <a asp-route-Date="@currentDay.ToString("yyyy-MM-dd")"
                class="magma-day text-decoration-none @(isSelected ? "selected" : "") @heatClass position-relative"
                title="@currentDay.ToString("D") - @count Rituals">

                @day

                @if (count > 1)
                {
                    <span class="magma-count-badge">@count</span>
                }
            </a>
        }
    </div>
</div>
