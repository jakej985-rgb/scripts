@model InfernalInkSteelSuite.Web.Models.AppointmentDto

<div class="card kanban-card mb-3 has-context-menu" data-context-type="appointment" data-id="@Model.Id" id="card-@Model.Id" draggable="true" ondragstart="drag(event)" data-id="@Model.Id">
    <div class="card-body p-3">
        <h6 class="card-title text-white mb-1">@Model.ClientName</h6>
        <div class="small text-muted mb-2">@Model.ServiceType</div>
        <div class="d-flex justify-content-between align-items-center">
            <span class="badge bg-dark border border-secondary text-secondary">
                <i class="bi bi-clock"></i> @Model.StartTime.ToString("MMM dd")
            </span>
            <span class="small text-muted">#@Model.Id</span>
        </div>
    </div>
</div>
