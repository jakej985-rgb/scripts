@page "{id:int?}"
@model InfernalInkSteelSuite.Web.Pages.Appointments.EditModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <form method="post">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>@Model.Title</h1>
                <div class="btn-group">
                    <a asp-page="/Appointments/Index" class="btn btn-outline-light">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save Appointment</button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <div asp-validation-summary="All" class="alert alert-warning"></div>

            <div class="card mb-4">
                <div class="card-header bg-transparent border-secondary">
                    <h5 class="mb-0">Details</h5>
                </div>
                <div class="card-body">
                    <input type="hidden" asp-for="Appointment.Id" />
                    <input type="hidden" asp-for="IsPopup" />

                    <div class="mb-3">
                        <label asp-for="Appointment.ClientId" class="form-label">Client</label>
                        <select asp-for="Appointment.ClientId" asp-items="Model.Clients" class="form-select" required>
                            <option value="">-- Select Client --</option>
                        </select>
                        <span asp-validation-for="Appointment.ClientId" class="text-warning"></span>
                        <div class="form-text">
                            <a asp-page="/Clients/Edit" target="_blank">Create new client</a>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Appointment.StartTime" class="form-label">Start Time</label>
                            <input asp-for="Appointment.StartTime" class="form-control" type="datetime-local"
                                required />
                            <span asp-validation-for="Appointment.StartTime" class="text-warning"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Appointment.EndTime" class="form-label">End Time</label>
                            <input asp-for="Appointment.EndTime" class="form-control" type="datetime-local" required />
                            <span asp-validation-for="Appointment.EndTime" class="text-warning"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Appointment.ServiceType" class="form-label">Service Type</label>
                            <select asp-for="Appointment.ServiceType" asp-items="Model.ServiceTypes" class="form-select"
                                required>
                                <option value="">-- Select Service --</option>
                            </select>
                            <span asp-validation-for="Appointment.ServiceType" class="text-warning"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Appointment.ArtistId" class="form-label">Artist</label>
                            <select asp-for="Appointment.ArtistId" asp-items="Model.Artists" class="form-select"
                                required>
                                <option value="">-- Select Artist --</option>
                            </select>
                            <span asp-validation-for="Appointment.ArtistId" class="text-warning"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-transparent border-secondary">
                    <h5 class="mb-0">Notes</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Appointment.Notes" class="form-label">Appointment Notes</label>
                        <textarea asp-for="Appointment.Notes" class="form-control" rows="5"></textarea>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
