@page
@model InfernalInkSteelSuite.Web.Pages.Financial.DepositsModel
@{
    ViewData["Title"] = "Blood Oaths (Deposits)";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h1 class="text-uppercase mb-4" style="color: var(--primary-color);">Blood Oaths</h1>
        <p class="mb-5 text-muted">Secure the commitment of the soul. A sacrifice is required to book the ritual.</p>

        <div class="card bg-dark border-secondary">
            <div class="card-body p-4">
                <form id="deposit-form" onsubmit="processDeposit(event)">
                    <div class="mb-4">
                        <label class="form-label text-uppercase">Client Name</label>
                        <input type="text" class="form-control" placeholder="e.g. John Doe">
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-uppercase">Sacrifice Amount ($)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-secondary border-secondary text-white">$</span>
                            <input type="number" class="form-control" placeholder="66.60" required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-uppercase">Payment Method</label>
                        <select class="form-select">
                            <option>Credit Card (Stripe)</option>
                            <option>Cash (Handshake)</option>
                            <option>Soul Shard (Gift Card)</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 btn-lg text-uppercase fw-bold">
                        <i class="bi bi-droplet-fill"></i> Collect Oath
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function processDeposit(e) {
        e.preventDefault();
        const btn = e.target.querySelector('button');
        const originalText = btn.innerHTML;
        
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Transmuting Gold...';
        
        setTimeout(() => {
            btn.innerHTML = originalText;
            btn.disabled = false;
            showOmen("Blood Oath Accepted. The pact is sealed.", "success");
            e.target.reset();
        }, 2000);
    }
</script>
