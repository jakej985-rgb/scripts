@page
@{
    ViewData["Title"] = "Ritual Failed";
    Layout = "_Layout";
}

<div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 70vh; text-align: center;">
    <div class="mb-4" style="color: var(--primary-color); font-size: 5rem;">
        <i class="bi bi-exclamation-octagon-fill"></i>
    </div>

    <h1 class="text-uppercase mb-3" style="letter-spacing: 3px; color: var(--primary-color);">Ritual Failed</h1>
    <h3 class="fw-light text-muted mb-4">Error 500</h3>

    <div class="mb-5" style="max-width: 600px; color: var(--text-secondary);">
        <p>The incantation was interrupted. Our scribes have been notified of this disturbance in the ether.</p>
        <p>Realign your chakras and try again later.</p>
    </div>

    <div class="d-flex gap-3">
        <a href="javascript:history.back()" class="btn btn-outline-light">
            <i class="bi bi-arrow-counterclockwise"></i> Retry
        </a>
        <a asp-page="/Dashboard/Index" class="btn btn-primary">
            <i class="bi bi-house-door"></i> Sanctuary
        </a>
    </div>
</div>
