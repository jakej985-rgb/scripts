@page
@model InfernalInkSteelSuite.Web.Pages.Account.LoginModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "The Gate";
}

<div class="login-gate-container">
    <div class="login-gate-panel">
        <div class="gate-header">
             @if (!string.IsNullOrEmpty(Model.Settings.LogoPath))
            {
                <img src="@Model.Settings.LogoPath" alt="Logo" class="gate-logo" />
            }
            <h1 class="gate-title">@Model.Settings.ShopName</h1>
            <p class="gate-subtitle">Enter the Void</p>
        </div>

        @if (Model.Settings.IsSpecialMessageEnabled && !string.IsNullOrEmpty(Model.Settings.SpecialMessageText))
        {
            <div class="gate-message">
                @Model.Settings.SpecialMessageText
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="gate-error">@Model.ErrorMessage</div>
        }

        <form method="post" class="gate-form">
            <div class="gate-input-group">
                <input asp-for="Username" class="gate-input" placeholder=" " />
                <label asp-for="Username" class="gate-label">Username</label>
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="gate-input-group">
                <input asp-for="Password" type="password" class="gate-input" placeholder=" " />
                <label asp-for="Password" class="gate-label">Password</label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-gate-primary">
                <span>Unlock</span>
                <div class="btn-gate-glow"></div>
            </button>
        </form>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Settings.LoginBackgroundPath))
{
    <style>
        .login-gate-body {
            background-image: url('@Model.Settings.LoginBackgroundPath') !important;
        }
    </style>
}
