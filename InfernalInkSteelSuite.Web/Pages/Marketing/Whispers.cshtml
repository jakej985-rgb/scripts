@page
@model InfernalInkSteelSuite.Web.Pages.Marketing.WhispersModel
@{
    ViewData["Title"] = "Whispers";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h1 class="text-uppercase mb-4 text-center" style="color: var(--primary-color);">Whispers</h1>
        <p class="text-center text-muted mb-5">Echoes of gratitude and pain from the mortal realm.</p>

        <div class="review-stats d-flex justify-content-center gap-4 mb-5">
            <div class="text-center">
                <h2 class="display-4 fw-bold text-white mb-0">4.9</h2>
                <div class="text-warning">
                    <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                        class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                </div>
                <small class="text-muted">Total Rating</small>
            </div>
            <div class="vr bg-secondary"></div>
            <div class="text-center">
                <h2 class="display-4 fw-bold text-white mb-0">666</h2>
                <small class="text-muted">Total Reviews</small>
            </div>
        </div>

        <!-- Review List -->
        <div class="review-card card bg-dark border-secondary mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <h5 class="text-white">Sarah M.</h5>
                    <div class="text-warning small">
                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                            class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                    </div>
                </div>
                <h6 class="text-muted small mb-3">Ritual: Full Sleeve by Damien</h6>
                <div class="review-quote border-start border-3 border-primary ps-3 fst-italic text-light">
                    "The pain was exquisite, the art divine. I have never felt more alive than when under the needle
                    here. Highly recommended for those seeking transformation."
                </div>
                <div class="mt-3 d-flex justify-content-between align-items-center">
                    <small class="text-muted">Posted 2 days ago</small>
                    <button class="btn btn-sm btn-outline-light" onclick="toggleReply(this)">Reply</button>
                </div>

                <!-- Admin Reply Area -->
                <div class="reply-box mt-3 d-none animation-fade-in">
                    <textarea class="form-control bg-black text-white border-secondary mb-2" rows="2"
                        placeholder="Whisper back..."></textarea>
                    <button class="btn btn-sm btn-primary" onclick="sendReply(this)">Send Whisper</button>
                </div>
            </div>
        </div>

        <div class="review-card card bg-dark border-secondary mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <h5 class="text-white">Mike R.</h5>
                    <div class="text-warning small">
                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i
                            class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                    </div>
                </div>
                <h6 class="text-muted small mb-3">Ritual: Piercing by Access</h6>
                <div class="review-quote border-start border-3 border-primary ps-3 fst-italic text-light">
                    "Clean, professional, and terrifyingly atmospheric. 10/10."
                </div>
                <div class="mt-3 d-flex justify-content-between align-items-center">
                    <small class="text-muted">Posted 1 week ago</small>
                    <button class="btn btn-sm btn-outline-light" onclick="toggleReply(this)">Reply</button>
                </div>
                <div class="reply-box mt-3 d-none animation-fade-in">
                    <textarea class="form-control bg-black text-white border-secondary mb-2" rows="2"
                        placeholder="Whisper back..."></textarea>
                    <button class="btn btn-sm btn-primary" onclick="sendReply(this)">Send Whisper</button>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    function toggleReply(btn) {
        const box = btn.closest('.card-body').querySelector('.reply-box');
        box.classList.toggle('d-none');
    }

    function sendReply(btn) {
        const box = btn.closest('.reply-box');
        const text = box.querySelector('textarea').value;
        if (text) {
            showOmen("Reply sent to the void.", "success");
            box.classList.add('d-none');
        }
    }
</script>

<style>
    .review-quote {
        background: rgba(255, 255, 255, 0.02);
        padding: 1rem;
        border-radius: 0 4px 4px 0;
    }

    .animation-fade-in {
        animation: fadeIn 0.3s;
    }
</style>
