@page
@model InfernalInkSteelSuite.Web.Pages.Marketing.InfectionModel
@{
    ViewData["Title"] = "The Infection";
    Layout = "_Layout";
}

<div class="row mb-5 text-center">
    <div class="col-12">
        <h1 class="text-uppercase" style="color: var(--primary-color);">Viral Spread</h1>
        <p class="text-muted">Tracking the contagion of your influence across the mortal realm.</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-10 bg-black rounded border border-secondary p-5 position-relative overflow-hidden"
        style="height: 600px;">

        <!-- Nodes -->
        <div class="infection-node patient-zero" style="top: 50%; left: 50%; transform: translate(-50%, -50%);">
            <i class="bi bi-radioactive display-4 text-danger"></i>
            <div class="small fw-bold text-white mt-2">YOU</div>
        </div>

        <div class="infection-node" style="top: 20%; left: 20%;">
            <i class="bi bi-person-fill fs-2 text-warning"></i>
        </div>
        <div class="infection-node" style="top: 30%; left: 80%;">
            <i class="bi bi-person-fill fs-2 text-warning"></i>
        </div>
        <div class="infection-node" style="top: 80%; left: 40%;">
            <i class="bi bi-person-fill fs-2 text-warning"></i>
        </div>
        <div class="infection-node" style="top: 70%; left: 70%;">
            <i class="bi bi-person-fill fs-2 text-warning"></i>
        </div>

        <!-- Connecting Lines (SVG overlay could be used, simplified here with absolutes) -->
        <div class="infection-line" style="top: 35%; left: 35%; width: 15%; transform: rotate(45deg);"></div>
        <div class="infection-line" style="top: 40%; left: 65%; width: 15%; transform: rotate(-30deg);"></div>
        <div class="infection-line" style="top: 65%; left: 45%; width: 10%; transform: rotate(90deg);"></div>
        <div class="infection-line" style="top: 60%; left: 60%; width: 15%; transform: rotate(20deg);"></div>

    </div>
</div>

<style>
    .infection-node {
        position: absolute;
        text-align: center;
        z-index: 2;
        animation: pulseNode 3s infinite;
    }

    .patient-zero {
        animation: pulseZero 2s infinite;
    }

    .infection-line {
        position: absolute;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--primary-color), transparent);
        opacity: 0.5;
        z-index: 1;
    }

    @@keyframes pulseNode {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.1);
        }

        100% {
            transform: scale(1);
        }
    }

    @@keyframes pulseZero {
        0% {
            transform: translate(-50%, -50%) scale(1);
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
            border-radius: 50%;
        }

        70% {
            transform: translate(-50%, -50%) scale(1.1);
            box-shadow: 0 0 0 20px rgba(220, 53, 69, 0);
            border-radius: 50%;
        }

        100% {
            transform: translate(-50%, -50%) scale(1);
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
            border-radius: 50%;
        }
    }
</style>
