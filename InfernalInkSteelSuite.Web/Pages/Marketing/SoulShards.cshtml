@page
@model InfernalInkSteelSuite.Web.Pages.Marketing.SoulShardsModel
@{
    ViewData["Title"] = "Soul Shards";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-6 mb-4">
        <h1 class="text-uppercase mb-4" style="color: var(--primary-color);">Soul Shards</h1>
        <p class="text-muted mb-5">Grant the gift of transformation. A fragment of value, bound to a future ritual.</p>

        <div class="card bg-dark border-secondary mb-4">
            <div class="card-body">
                <h4 class="text-white mb-3">Forge a New Shard</h4>
                <div class="mb-3">
                    <label class="form-label text-muted">Recipient Name</label>
                    <input type="text" class="form-control bg-black text-white border-secondary" id="shard-recipient"
                        oninput="updateCard()">
                </div>
                <div class="mb-4">
                    <label class="form-label text-muted">Value</label>
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" name="shard-val" id="val1" autocomplete="off" value="50"
                            onchange="updateCard()">
                        <label class="btn btn-outline-secondary" for="val1">$50</label>

                        <input type="radio" class="btn-check" name="shard-val" id="val2" autocomplete="off" value="100"
                            checked onchange="updateCard()">
                        <label class="btn btn-outline-secondary" for="val2">$100</label>

                        <input type="radio" class="btn-check" name="shard-val" id="val3" autocomplete="off" value="666"
                            onchange="updateCard()">
                        <label class="btn btn-outline-secondary" for="val3">$666</label>
                    </div>
                </div>
                <button class="btn btn-primary w-100 btn-lg" onclick="forgeShard()">Forge Shard</button>
            </div>
        </div>

        <div class="card bg-dark border-secondary">
            <div class="card-body">
                <h4 class="text-white mb-3">Redeem Shard</h4>
                <div class="input-group">
                    <input type="text" class="form-control bg-black text-white border-secondary"
                        placeholder="Enter Shard Code (e.g. X7-B9-...)">
                    <button class="btn btn-outline-light">Verify</button>
                </div>
            </div>
        </div>
    </div>

    <div
        class="col-md-6 d-flex align-items-center justify-content-center bg-black bg-opacity-50 rounded border border-secondary p-5">
        <!-- Visual Card Representation -->
        <div id="soul-shard-card" class="soul-shard-card p-4 text-center position-relative shadow-lg">
            <div class="shard-border"></div>
            <div class="shard-logo mb-3"><i class="bi bi-suit-spade-fill display-1"></i></div>
            <h3 class="text-uppercase fw-bold mb-1" style="font-family: var(--font-heading)">Soul Shard</h3>
            <div class="fs-4 fst-italic text-muted mb-4">Infernal Ink & Steel</div>

            <div class="d-flex justify-content-between align-items-end mt-5 border-top border-secondary pt-3">
                <div class="text-start">
                    <small class="text-muted d-block text-uppercase" style="font-size: 0.7rem">Bound To</small>
                    <span id="card-name" class="fw-bold fs-5">Future Soul</span>
                </div>
                <div class="text-end">
                    <span id="card-value" class="display-6 fw-bold text-warning">$100.00</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function updateCard() {
        const name = document.getElementById('shard-recipient').value || "Future Soul";
        const val = document.querySelector('input[name="shard-val"]:checked').value;

        document.getElementById('card-name').innerText = name;
        document.getElementById('card-value').innerText = "$" + val + ".00";
    }

    function forgeShard() {
        // Animation simulation
        const card = document.getElementById('soul-shard-card');
        card.style.transform = "scale(1.05) rotate(2deg)";
        card.style.boxShadow = "0 0 50px var(--primary-color)";

        setTimeout(() => {
            card.style.transform = "scale(1) rotate(0deg)";
            card.style.boxShadow = "none";
            showOmen("Shard Forged Successfully.", "success");
        }, 500);
    }
</script>

<style>
    .soul-shard-card {
        width: 100%;
        max-width: 400px;
        aspect-ratio: 1.6/1;
        /* Credit card ratio */
        background: #111;
        border: 1px solid #444;
        border-radius: 12px;
        transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .soul-shard-card .shard-border {
        position: absolute;
        top: 10px;
        left: 10px;
        right: 10px;
        bottom: 10px;
        border: 2px solid #333;
        border-radius: 8px;
        pointer-events: none;
    }
</style>
