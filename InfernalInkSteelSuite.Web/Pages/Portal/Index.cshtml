@page
@model InfernalInkSteelSuite.Web.Pages.Portal.IndexModel
@{
    ViewData["Title"] = "The Antechamber";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h1 class="text-uppercase mb-4 text-center" style="color: var(--primary-color);">The Antechamber</h1>

        <!-- Mock Login State -->
        <div class="card bg-dark border-secondary mb-5">
            <div class="card-body p-4 text-center">
                <i class="bi bi-person-circle display-4 text-muted mb-3"></i>
                <h4 class="text-white">Welcome back, initiates.</h4>
                <p class="text-muted">View your upcoming rituals and aftercare instructions.</p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card h-100 bg-dark border-secondary p-3">
                    <h5 class="text-white text-uppercase"><i class="bi bi-calendar-event"></i> Upcoming Rituals</h5>
                    <hr class="border-secondary">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-primary text-white p-2 rounded me-3 text-center" style="min-width: 50px;">
                            <div class="fw-bold">OCT</div>
                            <div>31</div>
                        </div>
                        <div>
                            <div class="text-white fw-bold">Full Back Piece</div>
                            <div class="text-muted small">with Damien Thorn</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 bg-dark border-secondary p-3">
                    <h5 class="text-white text-uppercase"><i class="bi bi-droplet"></i> Aftercare</h5>
                    <hr class="border-secondary">
                    <ul class="list-unstyled text-muted small">
                        <li class="mb-2"><i class="bi bi-check-circle text-success"></i> Keep area clean and dry.</li>
                        <li class="mb-2"><i class="bi bi-check-circle text-success"></i> Apply ointment 3x daily.</li>
                        <li class="mb-2"><i class="bi bi-x-circle text-danger"></i> Do not scratch or peel.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
