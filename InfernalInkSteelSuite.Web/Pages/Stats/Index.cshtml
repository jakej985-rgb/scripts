@page
@model InfernalInkSteelSuite.Web.Pages.Stats.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Statistics";
}

<h2>Statistics</h2>

@if (Model.Stats is null)
{
    <div class="alert alert-warning">No statistics available.</div>
}
else
{
    <div class="stats-dashboard">
        <!-- Quick Stats Row -->
        <div class="stats-row">
            <div class="stat-card stat-fire">
                <div class="stat-value">@Model.Stats.AppointmentsToday</div>
                <div class="stat-label">Appointments Today</div>
                <div class="stat-icon"><i class="bi bi-calendar-event"></i></div>
            </div>
            <div class="stat-card stat-void">
                <div class="stat-value">@Model.Stats.TotalClients</div>
                <div class="stat-label">Total Clients</div>
                <div class="stat-icon"><i class="bi bi-people"></i></div>
            </div>
            <div class="stat-card stat-gold">
                <div class="stat-value">@Model.Stats.ActiveArtistsCount</div>
                <div class="stat-label">Active Artists</div>
                <div class="stat-icon"><i class="bi bi-palette"></i></div>
            </div>
        </div>

        <!-- Visual Charts (Mocked Data for Visual Demo as backend doesn't support time-series yet) -->
        <div class="chart-container">
            <h4 class="chart-title">Weekly Activity (Heatmap)</h4>
            <div class="heatmap-grid">
                @for (int i = 0; i < 7; i++)
                {
                    var height = new Random().Next(20, 100);
                    <div class="heatmap-col">
                        <div class="heatmap-bar" style="height: @height%;"></div>
                        <span class="heatmap-label">@DateTime.Now.AddDays(-6+i).ToString("ddd")</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <style>
        .stats-dashboard {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }

        .stat-card {
            background: rgba(30, 30, 30, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 1.5rem;
            position: relative;
            overflow: hidden;
            border-radius: 4px;
        }

        .stat-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
        }

        .stat-fire::after {
            background: var(--primary-color);
            box-shadow: 2px 0 10px rgba(255, 0, 0, 0.4);
        }

        .stat-void::after {
            background: #5bc0de;
            box-shadow: 2px 0 10px rgba(91, 192, 222, 0.4);
        }

        .stat-gold::after {
            background: #ffd700;
            box-shadow: 2px 0 10px rgba(255, 215, 0, 0.4);
        }

        .stat-value {
            font-size: 3rem;
            font-weight: 700;
            line-height: 1;
            font-family: var(--font-heading);
            color: var(--text-primary);
        }

        .stat-label {
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-secondary);
            margin-top: 0.5rem;
        }

        .stat-icon {
            position: absolute;
            top: 1rem;
            right: 1rem;
            font-size: 2.5rem;
            opacity: 0.1;
        }

        .chart-container {
            background: rgba(20, 20, 20, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 2rem;
            border-radius: 4px;
        }

        .chart-title {
            font-family: var(--font-heading);
            color: var(--text-secondary);
            margin-bottom: 2rem;
            text-transform: uppercase;
        }

        .heatmap-grid {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            height: 200px;
            gap: 10px;
            padding-bottom: 2rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .heatmap-col {
            flex: 1;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            position: relative;
        }

        .heatmap-bar {
            background: linear-gradient(to top, #330000, #ff5252);
            width: 100%;
            border-radius: 2px 2px 0 0;
            opacity: 0.8;
            transition: all 0.3s ease;
        }

        .heatmap-bar:hover {
            opacity: 1;
            box-shadow: 0 0 15px rgba(255, 82, 82, 0.4);
        }

        .heatmap-label {
            position: absolute;
            bottom: -25px;
            width: 100%;
            text-align: center;
            font-size: 0.8rem;
            color: var(--text-secondary);
        }
    </style>
}
