@page
@model InfernalInkSteelSuite.Web.Pages.Admin.KarmaLogsModel
@{
    ViewData["Title"] = "Karma Logs";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="text-uppercase" style="color: var(--primary-color);">Karma Logs</h1>
        <p class="text-muted">The scales of judgement. All actions are recorded here.</p>
    </div>
    <div>
        <button class="btn btn-outline-secondary"><i class="bi bi-filter"></i> Filter</button>
        <button class="btn btn-outline-danger ms-2"><i class="bi bi-trash"></i> Purge Old Logs</button>
    </div>
</div>

<div class="card bg-dark border-secondary">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0 align-middle">
            <thead>
                <tr class="text-uppercase text-secondary small">
                    <th class="ps-4">Timestamp</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Details</th>
                    <th>Karma</th>
                </tr>
            </thead>
            <tbody>
                <!-- Mock Data -->
                <tr>
                    <td class="ps-4 text-muted small">Oct 31, 11:42 PM</td>
                    <td><span class="text-white">Damien</span></td>
                    <td><span class="badge bg-success bg-opacity-25 text-success">Create</span></td>
                    <td class="text-muted">Created new Client "Lucifer Morningstar"</td>
                    <td><i class="bi bi-arrow-up text-success"></i> +10</td>
                </tr>
                <tr>
                    <td class="ps-4 text-muted small">Oct 31, 10:15 PM</td>
                    <td><span class="text-white">Lilith</span></td>
                    <td><span class="badge bg-warning bg-opacity-25 text-warning">Update</span></td>
                    <td class="text-muted">Rescheduled Appointment #666</td>
                    <td><i class="bi bi-dash text-secondary"></i> 0</td>
                </tr>
                <tr>
                    <td class="ps-4 text-muted small">Oct 31, 09:00 AM</td>
                    <td><span class="text-white">System</span></td>
                    <td><span class="badge bg-danger bg-opacity-25 text-danger">Delete</span></td>
                    <td class="text-muted">Purged 5 Abandoned Carts</td>
                    <td><i class="bi bi-arrow-down text-danger"></i> -5</td>
                </tr>
                <tr>
                    <td class="ps-4 text-muted small">Oct 30, 15:30 PM</td>
                    <td><span class="text-white">Access</span></td>
                    <td><span class="badge bg-info bg-opacity-25 text-info">Login</span></td>
                    <td class="text-muted">Successful authentication</td>
                    <td><i class="bi bi-check text-info"></i></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
