@page
@model InfernalInkSteelSuite.Web.Pages.Admin.CrystalBallModel
@{
    ViewData["Title"] = "Crystal Ball";
    Layout = "_Layout";
}

<div class="row justify-content-center mb-5">
    <div class="col-md-8 text-center position-relative">
        <div
            class="crystal-ball rounded-circle mx-auto d-flex align-items-center justify-content-center overflow-hidden">
            <div class="fog"></div>
            <div id="vision-text" class="text-white display-6 fw-bold position-relative z-index-2 text-shadow p-4">
                The mists obscure the future...
            </div>
        </div>
        <div class="crystal-stand mx-auto"></div>

        <button class="btn btn-outline-light mt-4 px-5" onclick="gazeIntoFuture()">
            <i class="bi bi-eye me-2"></i> Gaze Into The Abyss
        </button>
    </div>
</div>

<div class="row opacity-0 transition-opacity duration-1000" id="future-stats">
    <div class="col-md-6 mb-4">
        <h4 class="text-white border-bottom border-secondary pb-2">Prophesied Revenue</h4>
        <div class="d-flex align-items-end h-200px gap-2 mt-4">
            <div class="bg-secondary" style="width: 16%; height: 40%"></div>
            <div class="bg-secondary" style="width: 16%; height: 50%"></div>
            <div class="bg-secondary" style="width: 16%; height: 30%"></div>
            <div class="bg-secondary" style="width: 16%; height: 60%"></div>
            <div class="bg-primary shadow-glow" style="width: 16%; height: 85%"></div>
            <div class="bg-primary shadow-glow" style="width: 16%; height: 95%"></div>
        </div>
        <div class="d-flex justify-content-between text-muted small mt-2">
            <span>Past</span>
            <span>Future</span>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <h4 class="text-white border-bottom border-secondary pb-2">Doomed Souls (Client Influx)</h4>
        <div class="mt-4">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Next Week</span>
                <span class="text-success">+15%</span>
            </div>
            <div class="progress bg-dark h-10px mb-4">
                <div class="progress-bar bg-success" style="width: 65%"></div>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Next Month</span>
                <span class="text-success">+22%</span>
            </div>
            <div class="progress bg-dark h-10px">
                <div class="progress-bar bg-success" style="width: 82%"></div>
            </div>
        </div>
    </div>
</div>

<script>
    const prophecies = [
        "Wealth flows like blood...",
        "A dark stranger approaches...",
        "Prepare for the influx...",
        "The stars align for profit..."
    ];

    function gazeIntoFuture() {
        const ball = document.querySelector('.crystal-ball');
        const text = document.getElementById('vision-text');
        const stats = document.getElementById('future-stats');

        // Animating state
        ball.classList.add('active');
        text.style.opacity = 0;

        // Reveal
        setTimeout(() => {
            text.innerText = prophecies[Math.floor(Math.random() * prophecies.length)];
            text.style.opacity = 1;
            stats.classList.remove('opacity-0');
            showOmen("The veil is lifted.", "success");
        }, 2000);
    }
</script>

<style>
    .crystal-ball {
        width: 300px;
        height: 300px;
        background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.2), rgba(0, 0, 0, 0.8));
        box-shadow: 0 0 50px rgba(100, 200, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.1);
        position: relative;
        transition: box-shadow 1s;
    }

    .crystal-ball.active {
        box-shadow: 0 0 100px rgba(100, 200, 255, 0.6);
    }

    .crystal-stand {
        width: 150px;
        height: 40px;
        background: #222;
        border-radius: 50%;
        margin-top: -20px;
        box-shadow: 0 10px 20px black;
    }

    .fog {
        position: absolute;
        width: 200%;
        height: 200%;
        background: url('https://raw.githubusercontent.com/danielstuart14/CSS_FOG_ANIMATION/master/fog1.png');
        background-size: cover;
        opacity: 0.3;
        animation: drift 20s linear infinite;
    }

    @@keyframes drift {
        from {
            transform: translate(-50%, -50%) rotate(0deg);
        }

        to {
            transform: translate(-50%, -50%) rotate(360deg);
        }
    }

    .shadow-glow {
        box-shadow: 0 0 15px var(--primary-color);
    }
</style>
