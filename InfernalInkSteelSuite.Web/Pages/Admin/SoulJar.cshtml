@page
@model InfernalInkSteelSuite.Web.Pages.Admin.SoulJarModel
@{
    ViewData["Title"] = "Soul Jar Backups";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-6 text-center">
        <h1 class="text-uppercase mb-5" style="color: var(--primary-color);">Soul Jar</h1>

        <div class="soul-jar-container position-relative mb-5 mx-auto" style="width: 200px; height: 300px;">
            <div class="soul-jar-glass border border-secondary rounded-pill h-100 position-relative overflow-hidden"
                style="background: rgba(255, 255, 255, 0.05); box-shadow: 0 0 20px rgba(0,0,0,0.5);">
                <div id="soul-essence" class="position-absolute bottom-0 w-100 bg-primary"
                    style="height: 30%; transition: height 2s ease-in-out; opacity: 0.8; box-shadow: 0 0 30px var(--primary-color);">
                </div>
                <div class="bubble position-absolute bg-white rounded-circle"
                    style="width: 10px; height: 10px; bottom: 20px; left: 50%; opacity: 0.5; animation: bubbleUp 3s infinite;">
                </div>
            </div>
            <div class="jar-lid position-absolute top-0 start-50 translate-middle-x bg-dark border border-secondary w-75 rounded-top"
                style="height: 40px; margin-top: -20px;"></div>
        </div>

        <div class="card bg-dark border-secondary p-4">
            <h4 class="text-white mb-4">Extract Data Essence</h4>
            <div class="row g-3">
                <div class="col-md-6">
                    <select class="form-select bg-black text-white border-secondary">
                        <option>Client Registry</option>
                        <option>Appointment Ledger</option>
                        <option>Financial Manifest</option>
                        <option>Full System Backup</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <select class="form-select bg-black text-white border-secondary">
                        <option>JSON Artifact</option>
                        <option>CSV Scroll</option>
                        <option>XML Runes</option>
                    </select>
                </div>
                <div class="col-12 mt-4">
                    <button class="btn btn-primary btn-lg w-100" onclick="captureSoul()"><i class="bi bi-download"></i>
                        Capture Soul</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function captureSoul() {
        const essence = document.getElementById('soul-essence');
        essence.style.height = "90%";

        showOmen("Extracting soul data...", "info");

        setTimeout(() => {
            essence.style.height = "30%"; // Reset
            showOmen("Soul Capture Complete. Download started.", "success");
            // Mock download
        }, 2500);
    }
</script>

<style>
    @@keyframes bubbleUp {
        0% {
            bottom: 0;
            opacity: 0;
        }

        50% {
            opacity: 0.8;
        }

        100% {
            bottom: 100%;
            opacity: 0;
        }
    }
</style>
