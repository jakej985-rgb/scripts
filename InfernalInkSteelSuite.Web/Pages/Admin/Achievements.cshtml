@page
@model InfernalInkSteelSuite.Web.Pages.Admin.AchievementsModel
@{
    ViewData["Title"] = "Achievements";
    Layout = "_Layout";
}

<div class="text-center mb-5">
    <h1 class="text-uppercase" style="color: var(--primary-color);">Hall of Glory</h1>
    <p class="text-muted">Eternalize your triumphs in ink and blood.</p>
</div>

<div class="row g-4">
    <!-- Unlocked -->
    <div class="col-md-3">
        <div class="card bg-dark border-secondary h-100 text-center p-3 achievement-card unlocked">
            <i class="bi bi-droplet-fill display-3 text-danger mb-3"></i>
            <h5 class="text-white">First Blood</h5>
            <p class="small text-muted">Complete your first tattoo session.</p>
            <div class="badge bg-success">UNLOCKED</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-dark border-secondary h-100 text-center p-3 achievement-card unlocked">
            <i class="bi bi-moon-stars-fill display-3 text-warning mb-3"></i>
            <h5 class="text-white">Night Owl</h5>
            <p class="small text-muted">Work a session past midnight.</p>
            <div class="badge bg-success">UNLOCKED</div>
        </div>
    </div>

    <!-- Locked -->
    <div class="col-md-3">
        <div class="card bg-black border-secondary h-100 text-center p-3 achievement-card opacity-50">
            <i class="bi bi-currency-dollar display-3 text-secondary mb-3"></i>
            <h5 class="text-white">Soul Harvester</h5>
            <p class="small text-muted">Earn $10k in a single month.</p>
            <div class="progress mt-3 bg-dark h-5px">
                <div class="progress-bar bg-primary" style="width: 75%"></div>
            </div>
            <small class="text-muted mt-1">75% Complete</small>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-black border-secondary h-100 text-center p-3 achievement-card opacity-50">
            <i class="bi bi-brush-fill display-3 text-secondary mb-3"></i>
            <h5 class="text-white">Ink Master</h5>
            <p class="small text-muted">Complete 1000 tattoos.</p>
            <div class="progress mt-3 bg-dark h-5px">
                <div class="progress-bar bg-primary" style="width: 42%"></div>
            </div>
            <small class="text-muted mt-1">420/1000</small>
        </div>
    </div>
</div>

<style>
    .achievement-card.unlocked {
        border-color: var(--primary-color) !important;
        box-shadow: 0 0 15px rgba(220, 53, 69, 0.2);
    }
</style>
