<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Infernal Ink & Steel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InfernalInkSteelSuite.Web.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Oswald:wght@400;700&display=swap"
        rel="stylesheet">
    <style>
        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 250px;
            background-color: var(--bg-surface);
            border-right: 1px solid var(--glass-border);
            display: flex;
            flex-direction: column;
            padding: 1rem;
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 1000;
        }

        .sidebar-brand {
            font-family: var(--font-heading);
            font-size: 1.5rem;
            color: var(--accent-color);
            margin-bottom: 2rem;
            text-align: center;
        }

        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            flex-grow: 1;
        }

        .nav-item-link {
            display: block;
            padding: 0.75rem 1rem;
            color: var(--text-primary);
            text-decoration: none;
            border-radius: 4px;
            transition: background-color 0.2s, color 0.2s;
            font-family: var(--font-body);
        }

        .nav-item-link:hover,
        .nav-item-link.active {
            background-color: rgba(255, 82, 82, 0.1);
            color: var(--accent-color);
        }

        .main-content {
            flex-grow: 1;
            margin-left: 250px;
            /* Width of sidebar */
            padding: 2rem;
            background-color: var(--bg-dark);
        }

        .sidebar-footer {
            margin-top: auto;
            border-top: 1px solid var(--glass-border);
            padding-top: 1rem;
        }
    </style>
</head>

<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="sidebar-brand">
                INFERNAL INK
            </div>
            <nav class="sidebar-nav">
                <a asp-controller="Dashboard" asp-action="Index"
                    class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">Dashboard</a>
                <a asp-controller="Clients" asp-action="Index"
                    class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clients" ? "active" : "")">Clients</a>
                <a asp-controller="Appointments" asp-action="Index"
                    class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointments" ? "active" : "")">Appointments</a>
                <a asp-controller="Quotes" asp-action="Index"
                    class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Quotes" ? "active" : "")">Quotes</a>
                <a asp-controller="Documents" asp-action="Index"
                    class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Documents" ? "active" : "")">Documents</a>
                <a asp-controller="Statistics" asp-action="Index"
                    class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Statistics" ? "active" : "")">Statistics</a>
                <a asp-controller="Settings" asp-action="Index"
                    class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")">Settings</a>
            </nav>
            <div class="sidebar-footer">
                <a asp-controller="Account" asp-action="Logout" class="nav-item-link">Logout</a>
            </div>
        </aside>

        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
