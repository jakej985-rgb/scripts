@model List<InfernalInkSteelSuite.Web.Services.ApiClient.QuoteDto>
@{
    ViewData["Title"] = "Quotes";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Quotes</h1>
        <a asp-action="Create" class="btn btn-primary">New Smart Quote</a>
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Client ID</th>
                    <th>Style</th>
                    <th>Placement</th>
                    <th>Est. Hours</th>
                    <th>Price Range</th>
                    <th>Confidence</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CreatedAt.ToShortDateString()</td>
                        <td>@item.ClientId</td>
                        <td>@item.Style</td>
                        <td>@item.Placement</td>
                        <td>@item.EstimatedHoursLow - @item.EstimatedHoursHigh</td>
                        <td>$@item.PriceLow - $@item.PriceHigh</td>
                        <td>@(item.ConfidenceScore * 100)%</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
