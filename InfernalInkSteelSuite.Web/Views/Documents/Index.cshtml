@model List<InfernalInkSteelSuite.Web.Services.ApiClient.DocumentDto>
@{
    ViewData["Title"] = "Documents";
    int? clientId = ViewData["ClientId"] as int?;
}

<div class="container-fluid">
    <h1 class="mb-4">Documents</h1>

    @if (clientId.HasValue)
    {
        <div class="card mb-4 neon-border">
            <div class="card-header bg-transparent border-bottom border-secondary">
                <h5 class="mb-0">Upload New Document</h5>
            </div>
            <div class="card-body">
                <form asp-action="Upload" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="clientId" value="@clientId" />
                    <div class="row g-3">
                        <div class="col-md-5">
                            <input type="text" name="title" class="form-control bg-dark text-light border-secondary" placeholder="Document Title (optional)">
                        </div>
                        <div class="col-md-5">
                            <input type="file" name="file" class="form-control bg-dark text-light border-secondary" required>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">Upload</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">Please select a client from the Clients page to view and upload documents.</div>
    }

    <div class="row">
        @foreach (var doc in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card bg-dark text-light h-100 neon-hover">
                    <div class="card-body">
                        <h5 class="card-title">@doc.Title</h5>
                        <p class="card-text small text-muted">Uploaded: @doc.CreatedAt.ToLocalTime()</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-secondary">ID: @doc.Id</span>
                            <!-- Download link would point to API directly or proxy through Web Controller -->
                            <!-- Direct API link requires auth token, so proxy is better or JS fetch -->
                            <a href="#" class="btn btn-sm btn-outline-light">Download</a>
                        </div>
                    </div>
                </div>
            </div>
        }
        @if (!Model.Any() && clientId.HasValue)
        {
            <div class="col-12 text-center text-muted">
                <p>No documents found.</p>
            </div>
        }
    </div>
</div>
