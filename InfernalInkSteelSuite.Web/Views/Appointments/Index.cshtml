@using InfernalInkSteelSuite.Web.Models
@model IEnumerable<AppointmentDto>

@{
    ViewData["Title"] = "Appointments";
}

<h1>Appointments</h1>

<table class="table table-striped table-hover">
    <thead class="thead-dark">
        <tr>
            <th>Client</th>
            <th>Date</th>
            <th>Time</th>
            <th>Service</th>
            <th>Artist</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model)
        {
            <tr>
                <td>
                    @if (a.Client != null)
                    {
                        @a.Client.FullName
                    }
                    else
                    {
                            <span class="text-muted">Unknown</span>
                    }
                </td>
                <td>@a.StartTime.ToLocalTime().ToShortDateString()</td>
                <td>@a.StartTime.ToLocalTime().ToShortTimeString()</td>
                <td>@a.ServiceType <small class="text-muted">(@a.ServiceCategory)</small></td>
                <td>@a.ArtistName</td>
                <td>@a.Status</td>
            </tr>
        }
    </tbody>
</table>
