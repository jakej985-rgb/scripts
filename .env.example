PUID=1000
PGID=1000
TZ=America/Los_Angeles

MASTER_IP=192.168.1.10

# Telegram (optional)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# VPN Credentials (REQUIRED for gluetun/media stack)
VPN_USER=replace_me
VPN_PASSWORD=replace_me

# Tattoo App Database
TATTOO_DB_PASSWORD=replace_me

# Dashboard Auth Tokens (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
ADMIN_TOKEN=replace_me
OPS_TOKEN=replace_me
VIEW_TOKEN=replace_me

# Data directory for backups
DATA_DIR=/mnt

# Domain for Traefik routing
DOMAIN=local
